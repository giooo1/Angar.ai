# --- Secrets and environment ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
service_account.json

# --- Python (backend, scripts, eval harness) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.log

# --- Node / Next.js (frontend, when added) ---
node_modules/
.next/
out/
.turbo/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Streamlit (current demo) ---
.streamlit/secrets.toml

# --- Claude Code ---
# Track project-shared config (.claude/settings.json, .claude/commands/),
# but ignore machine-specific permission overrides and local state.
.claude/settings.local.json
.claude/*.local.json

# --- Editors / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Build / temp ---
*.tmp
*.bak
*.orig
tmp/
temp/

# --- Local-only operational data (do NOT commit) ---
# Cached RS.ge reference dictionaries, Oris export drops, etc.
.cache/
local_only/
scratch/

# --- Extraction outputs (regenerable; keep eval ground truth in /labels) ---
outputs/
*.extraction.json

# --- Eval harness runs (regenerable; one JSON per run; can grow large) ---
eval/runs/
eval/.cache/

# --- Backend local storage (SQLite DB + uploaded files) ---
backend/.local/
*.db
*.db-journal
*.sqlite
*.sqlite-journal
